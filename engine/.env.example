# Database
DB_URL=postgresql+psycopg2://vinculante:vinculante@postgres/vinculante
POSTGRES_USER=vinculante
POSTGRES_PASSWORD=vinculante
POSTGRES_DB=vinculante

# Cache
CACHE_REDIS_HOST=redis://redis

# LLM  (set LLM_PROVIDER to: anthropic | openai | google | mistral | ollama)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.0
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Embeddings (set EMBEDDING_PROVIDER to: openai | google | ollama)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Matching
MATCHING_TOP_K=5
MATCHING_CONFIDENCE_THRESHOLD=0.5
MATCHING_CONCURRENCY=4
