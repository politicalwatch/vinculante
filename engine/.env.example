# Database
DB_URL=postgresql+psycopg2://vinculante:vinculante@postgres/vinculante
POSTGRES_USER=vinculante
POSTGRES_PASSWORD=vinculante
POSTGRES_DB=vinculante

# Cache
CACHE_REDIS_HOST=redis://redis

# LLM  (set LLM_PROVIDER to: anthropic | openai | google | mistral | ollama)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.0
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Embeddings (set EMBEDDING_PROVIDER to: openai | google | ollama)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=embeddinggemma:300m

# Report Ingestion
REPORT_LLM_PROVIDER=
REPORT_LLM_MODEL=
REPORT_LLM_TEMPERATURE=

# Matching
MATCHING_TOP_K=5
MATCHING_CONFIDENCE_THRESHOLD=0.7
MATCHING_CONCURRENCY=4
MATCHING_STRATEGY=one-to-many-critic
MATCHING_PROMPT_VERSION=v4
MATCHING_CRITIC_PROMPT_VERSION=v1

# Summary
SUMMARY_LLM_PROVIDER=
SUMMARY_LLM_MODEL=
SUMMARY_TEMPERATURE=0.3
SUMMARY_PROMPT_VERSION=v1